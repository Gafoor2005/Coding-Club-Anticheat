<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Coding_Club_Anticheat.TestLaunchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Coding_Club_Anticheat"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Background gradient overlay -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#161B22" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Back Button Bar -->
        <Border Grid.Row="0" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                Padding="20,12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Button x:Name="BackButton"
                    Click="BackButton_Click"
                    Style="{StaticResource DefaultButtonStyle}"
                    Padding="12,8"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    <TextBlock Text="Back" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" Padding="0,32,0,32">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="700"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*" MaxWidth="700"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" Spacing="24" Margin="24,0">
                    <!-- Header with Test Title -->
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="TestTitleText"
                                   Text="🎯 Programming Test"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   TextAlignment="Left"
                                   TextWrapping="Wrap"
                                   Foreground="White"/>
                        <TextBlock x:Name="TestCodeDisplay"
                                   Text="Code: 1234"
                                   FontSize="16"
                                   Foreground="#8B949E"/>
                    </StackPanel>

                    <!-- Test Details Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="12"
                            Padding="24"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="#58A6FF"/>
                                <TextBlock Text="Test Information"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            
                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                            
                            <StackPanel Spacing="12">
                                <!-- Test Title -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📝" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="Title:" 
                                               FontSize="14" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Width="100"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="2"
                                               x:Name="TestTitleDetail"
                                               Text="Programming Problems"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </Grid>
                                
                                <!-- Test Code -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🔑" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="Access Code:" 
                                               FontSize="14" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Width="100"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="2"
                                               x:Name="TestCodeDetail"
                                               Text="1234"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                </Grid>
                                
                                <!-- Usage Count -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📊" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="Times Used:" 
                                               FontSize="14" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Width="100"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="2"
                                               x:Name="UsageCountDetail"
                                               Text="42 students"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2" Spacing="24" Margin="0,0,24,0">
                    <!-- Zero Tolerance Warning Card -->
                    <Border Background="#2D1B1B"
                            CornerRadius="12"
                            Padding="24"
                            BorderBrush="#D73A49"
                            BorderThickness="2">
                        <StackPanel Spacing="16">
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="🚨" FontSize="24"/>
                                <TextBlock Text="ZERO-TOLERANCE MODE"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FF3B30"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Description -->
                            <TextBlock Text="ANY violation will result in IMMEDIATE test termination."
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Foreground="#FFB3B3"
                                       FontWeight="Medium"/>
                            
                            <!-- Expandable Rules Section -->
                            <Expander x:Name="RulesExpander"
                                      HorizontalAlignment="Stretch"
                                      Background="#1C1C1C"
                                      CornerRadius="8">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8BC;" FontSize="14" Foreground="#FF3B30"/>
                                        <TextBlock Text="View Prohibited Actions" 
                                                   FontSize="14" 
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Padding="12" Spacing="8">
                                    <!-- Rule Items -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="❌" FontSize="14"/>
                                        <TextBlock Text="Tab Switching → Instant termination"
                                                   FontSize="13"
                                                   Foreground="#FFB3B3"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="❌" FontSize="14"/>
                                        <TextBlock Text="Copy/Paste → Instant termination"
                                                   FontSize="13"
                                                   Foreground="#FFB3B3"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="❌" FontSize="14"/>
                                        <TextBlock Text="Developer Tools → Instant termination"
                                                   FontSize="13"
                                                   Foreground="#FFB3B3"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="❌" FontSize="14"/>
                                        <TextBlock Text="Right-Click → Instant termination"
                                                   FontSize="13"
                                                   Foreground="#FFB3B3"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="❌" FontSize="14"/>
                                        <TextBlock Text="External Navigation → Instant termination"
                                                   FontSize="13"
                                                   Foreground="#FFB3B3"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="❌" FontSize="14"/>
                                        <TextBlock Text="Window Focus Loss → Instant termination"
                                                   FontSize="13"
                                                   Foreground="#FFB3B3"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <!-- Final Warning Banner -->
                    <Border Background="#FF9500"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <TextBlock Text="⚠️" FontSize="20"/>
                            <TextBlock Text="This is your ONLY chance!"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Bottom Action Bar with Prominent Launch Button -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Cancel Button (Left) -->
                <Button x:Name="CancelButton"
                        Grid.Column="0"
                        Content="Cancel"
                        Width="120"
                        Height="48"
                        FontSize="15"
                        Click="CancelButton_Click"
                        Style="{StaticResource DefaultButtonStyle}"
                        CornerRadius="8">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Escape"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <!-- Launch Button (Right) - Prominent & Eye-catching -->
                <Button x:Name="LaunchButton"
                        Grid.Column="2"
                        Height="56"
                        MinWidth="320"
                        FontSize="16"
                        Click="LaunchButton_Click"
                        CornerRadius="10"
                        Padding="32,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#667eea" Offset="0"/>
                            <GradientStop Color="#764ba2" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                    </Button.Resources>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter"/>
                    </Button.KeyboardAccelerators>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE7C8;" FontSize="20" Foreground="White"/>
                        <TextBlock Text="I Understand - Launch Test"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
